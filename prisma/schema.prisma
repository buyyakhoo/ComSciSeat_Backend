generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model users {
  user_id    String          @id(map: "users_new_pkey") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  student_id String?         @db.Char(8)
  email      String          @unique(map: "users_new_email_key") @db.VarChar(255)
  name       String          @db.VarChar(255)
  user_type  user_type_enum? @default(student)
  bookings   bookings[]
}

model bookings {
  booking_id   Int            @id(map: "bookings_new_pkey") @default(autoincrement())
  user_id      String?        @db.Uuid
  table_id     Int?
  booking_date DateTime       @db.Date
  slot         time_slot_enum
  created_at   DateTime?      @default(now()) @db.Timestamp(6)
  tables       tables?        @relation(fields: [table_id], references: [table_id], onDelete: Cascade, onUpdate: NoAction, map: "bookings_new_table_id_fkey")
  users        users?         @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "bookings_new_user_id_fkey")

  @@unique([table_id, booking_date, slot], map: "unique_table_booking")
  @@unique([user_id, booking_date, slot], map: "unique_user_per_slot")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model class_schedule {
  class_id    Int            @id @default(autoincrement())
  lab_id      Int?
  day_of_week Int?
  slot        time_slot_enum
  subject     String         @db.VarChar(50)
  labs        labs?          @relation(fields: [lab_id], references: [lab_id], onDelete: Cascade, onUpdate: NoAction)
}

model labs {
  lab_id         Int              @id @default(autoincrement())
  lab_name       String           @unique(map: "unique_lab_name") @db.VarChar(100)
  lab_code       String           @db.VarChar(50)
  class_schedule class_schedule[]
  tables         tables[]
}

model tables {
  table_id   Int        @id @default(autoincrement())
  table_code String     @db.VarChar(3)
  lab_id     Int?
  bookings   bookings[]
  labs       labs?      @relation(fields: [lab_id], references: [lab_id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([lab_id, table_code], map: "unique_table_code_per_lab")
}

enum user_type_enum {
  student
  admin
}

enum time_slot_enum {
  Morning
  Lunch
  Afternoon
}
